5.2 Complete Database Schema
Table 1: manufacturers
sql
CREATE TABLE manufacturers (
  manufacturer_id VARCHAR(50) PRIMARY KEY,
  company_name VARCHAR(255) NOT NULL,
  license_number VARCHAR(100) UNIQUE NOT NULL,
  address TEXT,
  city VARCHAR(100),
  state VARCHAR(100),
  country VARCHAR(100) DEFAULT 'India',
  contact_email VARCHAR(255),
  contact_phone VARCHAR(50),
  status VARCHAR(20) DEFAULT 'active' CHECK (status IN ('active', 'suspended', 'inactive')),
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Indexes
CREATE INDEX idx_manufacturers_status ON manufacturers(status);
CREATE INDEX idx_manufacturers_license ON manufacturers(license_number);
Purpose: Store pharmaceutical companies that are authorized to manufacture medicines.

Sample Data:

sql
INSERT INTO manufacturers VALUES 
('MFR-PFZ-001', 'Pfizer India Limited', 'LIC-PFZ-2024-001', 
 'Pfizer Complex, Village Thokarpur', 'Mumbai', 'Maharashtra', 'India',
 'contact@pfizerindia.com', '+91-22-6693-4444', 'active', NOW(), NOW());
Table 2: products
sql
CREATE TABLE products (
  product_id VARCHAR(50) PRIMARY KEY,
  manufacturer_id VARCHAR(50) NOT NULL REFERENCES manufacturers(manufacturer_id) ON DELETE CASCADE,
  product_name VARCHAR(255) NOT NULL,
  generic_name VARCHAR(255),
  gtin VARCHAR(14) NOT NULL UNIQUE,  -- Global Trade Item Number (GS1)
  strength VARCHAR(50),               -- e.g., "500mg"
  dosage_form VARCHAR(100),           -- e.g., "Tablet", "Syrup"
  packaging VARCHAR(100),             -- e.g., "10 tablets per strip"
  registration_number VARCHAR(100),   -- Drug regulatory approval number
  approved_by VARCHAR(100),           -- e.g., "CDSCO" (India), "FDA" (USA)
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Indexes
CREATE INDEX idx_products_manufacturer ON products(manufacturer_id);
CREATE INDEX idx_products_gtin ON products(gtin);
CREATE INDEX idx_products_name ON products(product_name);
Purpose: Store medicine product catalog.

Sample Data:

sql
INSERT INTO products VALUES 
('PROD-ASP-500', 'MFR-PFZ-001', 'Aspirin', 'Acetylsalicylic Acid',
 '05412345678900', '500mg', 'Tablet', '10 tablets per strip',
 'REG-IND-2024-001', 'CDSCO', NOW(), NOW());
Table 3: boxes (Hierarchical tracking)
sql
CREATE TABLE boxes (
  box_id VARCHAR(50) PRIMARY KEY,
  product_id VARCHAR(50) NOT NULL REFERENCES products(product_id) ON DELETE CASCADE,
  batch_number VARCHAR(100) NOT NULL,
  box_qr_code VARCHAR(200) UNIQUE NOT NULL,
  total_medicines INTEGER DEFAULT 100,
  manufacturing_date DATE NOT NULL,
  expiry_date DATE NOT NULL,
  status VARCHAR(20) DEFAULT 'manufactured' CHECK (status IN ('manufactured', 'in_transit', 'at_wholesaler', 'at_pharmacy', 'opened')),
  seal_code VARCHAR(100),  -- Tamper-evident seal code
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Indexes
CREATE INDEX idx_boxes_batch ON boxes(batch_number);
CREATE INDEX idx_boxes_qr ON boxes(box_qr_code);
CREATE INDEX idx_boxes_status ON boxes(status);
Purpose: Track shipping boxes containing 100 medicines each.

Sample Data:

sql
INSERT INTO boxes VALUES 
('BOX-2024-001', 'PROD-ASP-500', 'BATCH-2024-001', 
 'BOX-QR-2024-001', 100, '2024-02-01', '2026-02-01',
 'manufactured', 'SEAL-ABC123', NOW(), NOW());
Table 4: serial_numbers ⭐ MAIN TABLE
sql
CREATE TABLE serial_numbers (
  serial_number VARCHAR(100) PRIMARY KEY,
  product_id VARCHAR(50) NOT NULL REFERENCES products(product_id) ON DELETE CASCADE,
  box_id VARCHAR(50) REFERENCES boxes(box_id) ON DELETE SET NULL,
  batch_number VARCHAR(100) NOT NULL,
  manufacturing_date DATE NOT NULL,
  expiry_date DATE NOT NULL,
  gs1_data TEXT,  -- Complete GS1 barcode string
  qr_code_url TEXT,  -- S3 URL or base64 data
  status VARCHAR(20) DEFAULT 'manufactured' 
    CHECK (status IN ('manufactured', 'in_transit', 'at_wholesaler', 'at_pharmacy', 'dispensed', 'recalled', 'expired')),
  current_location VARCHAR(100),  -- Current pharmacy/warehouse ID
  dispensed_at TIMESTAMP,
  dispensed_by VARCHAR(100),  -- Pharmacist ID
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Indexes (CRITICAL FOR PERFORMANCE)
CREATE INDEX idx_serial_product ON serial_numbers(product_id);
CREATE INDEX idx_serial_box ON serial_numbers(box_id);
CREATE INDEX idx_serial_batch ON serial_numbers(batch_number);
CREATE INDEX idx_serial_status ON serial_numbers(status);
CREATE INDEX idx_serial_expiry ON serial_numbers(expiry_date);
CREATE INDEX idx_serial_location ON serial_numbers(current_location);
Purpose: Store every individual medicine package. This table will have millions of rows.

Sample Data:

sql
INSERT INTO serial_numbers VALUES 
('2024-PFZ-ASP-0000001', 'PROD-ASP-500', 'BOX-2024-001', 'BATCH-2024-001',
 '2024-02-01', '2026-02-01', '(01)05412345678900(21)2024-PFZ-ASP-0000001(17)260201(10)BATCH-2024-001',
 'data:image/png;base64,...', 'manufactured', NULL, NULL, NULL, NOW(), NOW());
Table 5: box_contents (Mapping table)
sql
CREATE TABLE box_contents (
  id SERIAL PRIMARY KEY,
  box_id VARCHAR(50) NOT NULL REFERENCES boxes(box_id) ON DELETE CASCADE,
  serial_number VARCHAR(100) NOT NULL REFERENCES serial_numbers(serial_number) ON DELETE CASCADE,
  position INTEGER NOT NULL CHECK (position >= 1 AND position <= 100),
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  UNIQUE(box_id, serial_number),
  UNIQUE(box_id, position)
);

-- Indexes
CREATE INDEX idx_box_contents_box ON box_contents(box_id);
CREATE INDEX idx_box_contents_serial ON box_contents(serial_number);
Purpose: Map which medicines are in which box (many-to-many relationship).

Sample Data:

sql
INSERT INTO box_contents (box_id, serial_number, position) VALUES 
('BOX-2024-001', '2024-PFZ-ASP-0000001', 1),
('BOX-2024-001', '2024-PFZ-ASP-0000002', 2),
-- ... 98 more
('BOX-2024-001', '2024-PFZ-ASP-0000100', 100);
Table 6: supply_chain_actors
sql
CREATE TABLE supply_chain_actors (
  actor_id VARCHAR(50) PRIMARY KEY,
  actor_type VARCHAR(20) NOT NULL CHECK (actor_type IN ('manufacturer', 'wholesaler', 'distributor', 'pharmacy', 'hospital')),
  company_name VARCHAR(255) NOT NULL,
  license_number VARCHAR(100) UNIQUE NOT NULL,
  address TEXT,
  city VARCHAR(100),
  state VARCHAR(100),
  country VARCHAR(100) DEFAULT 'India',
  gln VARCHAR(13),  -- Global Location Number (GS1)
  contact_person VARCHAR(255),
  contact_email VARCHAR(255),
  contact_phone VARCHAR(50),
  latitude DECIMAL(10, 8),
  longitude DECIMAL(11, 8),
  status VARCHAR(20) DEFAULT 'active' CHECK (status IN ('active', 'suspended', 'inactive')),
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Indexes
