5.3 Database Performance Optimization
Why Indexing Matters:
Without Index:

sql
-- Search through 1 million records one by one
SELECT * FROM serial_numbers WHERE serial_number = '2024-PFZ-ASP-0000001';
-- Time: 5-10 seconds ❌
With Index (PRIMARY KEY):

sql
-- Jump directly to the record using B-tree index
SELECT * FROM serial_numbers WHERE serial_number = '2024-PFZ-ASP-0000001';
-- Time: 0.001-0.01 seconds ✅ (1000x faster!)
Index Strategy:
sql
-- ALWAYS index:
1. Primary keys (automatic)
2. Foreign keys
3. Columns used in WHERE clauses
4. Columns used in JOIN conditions
5. Columns used for sorting (ORDER BY)

-- NEVER index:
1. Columns with very few distinct values (e.g., boolean)
2. Small tables (< 1000 rows)
3. Columns rarely queried
Query Optimization Examples:
Bad Query (No index used):

sql
SELECT * FROM serial_numbers WHERE LOWER(batch_number) = 'batch-2024-001';
-- Function on column prevents index usage
-- Time: 5 seconds for 1M rows
Good Query (Uses index):

sql
SELECT * FROM serial_numbers WHERE batch_number = 'BATCH-2024-001';
-- Direct comparison uses idx_serial_batch index
-- Time: 0.01 seconds
*Bad Query (SELECT ):

sql
SELECT * FROM serial_numbers WHERE serial_number = '...';
-- Fetches ALL columns (waste of data transfer)
Good Query (SELECT specific columns):

sql
SELECT serial_number, status, expiry_date FROM serial_numbers WHERE serial_number = '...';
-- Fetches only needed columns
-- Faster and less memory
```

---

# **SECTION 6: FEATURE SPECIFICATIONS**

## **6.1 Serial Number Generation Algorithm**

### **Requirements:**
- Must be **unique** (no duplicates ever)
- Must be **unpredictable** (cannot guess next number)
- Must be **short enough** to fit in QR code
- Must contain **meaningful information** (year, manufacturer, product)

### **Format Design:**
```
Structure: [YEAR]-[MFR_CODE]-[PRODUCT_CODE]-[SEQUENCE]

Example: 2024-PFZ-ASP-0001234

Components:
├─ YEAR: 4 digits (2024)
├─ MFR_CODE: 3 letters (PFZ = Pfizer)
├─ PRODUCT_CODE: 3 letters (ASP = Aspirin)
└─ SEQUENCE: 7 digits (0001234)

Total length: 21 characters
Implementation:
javascript
// services/serializationService.js

const crypto = require('crypto');

class SerializationService {
  
  /**
   * Generate unique serial numbers for a batch
   * @param {string} productId - Product identifier
   * @param {number} quantity - How many serials to generate
   * @param {string} batchNumber - Batch identifier
   * @param {string} manufacturerCode - 3-letter manufacturer code
   * @param {string} productCode - 3-letter product code
   * @returns {Array} Array of serial numbers
   */
  async generateSerialNumbers(productId, quantity, batchNumber, manufacturerCode, productCode) {
    const serialNumbers = [];
    const year = new Date().getFullYear();
    
    // Get the last sequence number for this product
    const lastSerial = await this.getLastSequence(productId, year);
    let sequence = lastSerial + 1;
    
    for (let i = 0; i < quantity; i++) {
      // Format: YEAR-MFR-PROD-SEQUENCE
      const serialNumber = `${year}-${manufacturerCode}-${productCode}-${String(sequence).padStart(7, '0')}`;
      
      // Verify uniqueness (critical!)
      const exists = await this.checkSerialExists(serialNumber);
      if (exists) {
        // Extremely rare, but handle it
        sequence++;
        i--; // Retry this iteration
        continue;
      }
      
      serialNumbers.push({
        serialNumber,
        batchNumber,
        productId
      });
      
      sequence++;
    }
    
    return serialNumbers;
  }
  
  /**
   * Get last used sequence number
   */
  async getLastSequence(productId, year) {
    const result = await db.query(`
      SELECT serial_number 
      FROM serial_numbers 
      WHERE product_id = $1 
        AND serial_number LIKE $2
      ORDER BY serial_number DESC 
      LIMIT 1
    `, [productId, `${year}-%`]);
    
    if (!result.rows.length) {
      return 0; // First serial for this product this year
    }
    
    // Extract sequence from format: YEAR-MFR-PROD-SEQUENCE
    const parts = result.rows[0].serial_number.split('-');
    const lastSequence = parseInt(parts[3], 10);
    return lastSequence;
  }
  
  /**
   * Check if serial number already exists
   */
  async checkSerialExists(serialNumber) {
    const result = await db.query(
      'SELECT 1 FROM serial_numbers WHERE serial_number = $1',
      [serialNumber]
    );
    return result.rows.length > 0;
  }
  
  /**
   * Alternative: Add cryptographic randomness for extra security
   */
  generateCryptoSerial(prefix, sequence) {
    // Generate 4 random bytes
    const randomBytes = crypto.randomBytes(4);
    const randomHex = randomBytes.toString('hex').toUpperCase();
    
    // Format: PREFIX-SEQUENCE-RANDOM
    return `${prefix}-${String(sequence).padStart(7, '0')}-${randomHex}`;
    // Example: 2024-PFZ-ASP-0001234-A3F9B2C1
  }
}

module.exports = new SerializationService();
Box ID Generation:
javascript
/**
 * Generate box IDs for hierarchical tracking
 * @param {number} numBoxes - How many boxes needed
 * @param {string} batchNumber - Batch identifier
 * @returns {Array} Array of box objects
 */
async generateBoxes(numBoxes, batchNumber, productId) {
  const boxes = [];
  const year = new Date().getFullYear();
  
  // Get last box number
  const lastBoxNum = await this.getLastBoxNumber(year);
  let boxNum = lastBoxNum + 1;
  
  for (let i = 0; i < numBoxes; i++) {
    const boxId = `BOX-${year}-${String(boxNum).padStart(4, '0')}`;
    const boxQRCode = `BOX-QR-${year}-${String(boxNum).padStart(4, '0')}`;
    
    boxes.push({
      boxId,
      boxQRCode,
      batchNumber,
      productId,
      totalMedicines: 100
    });
    
    boxNum++;
  }
  
  return boxes;
}
6.2 QR Code Generation
GS1 Standard Format:
javascript
// services/qrcodeService.js

const QRCode = require('qrcode');

class QRCodeService {
  
  /**
   * Generate GS1-compliant Data Matrix barcode
   * @param {string} gtin - Global Trade Item Number (14 digits)
   * @param {string} serialNumber - Unique serial number
   * @param {string} expiryDate - Expiry date (YYMMDD format)
   * @param {string} batchNumber - Batch/lot number
   * @returns {Object} QR code data and image
   */
  async generateDataMatrix(gtin, serialNumber, expiryDate, batchNumber) {
    
    // GS1 Application Identifiers:
    // (01) = GTIN
    // (21) = Serial Number
    // (17) = Expiry Date (YYMMDD)
    // (10) = Batch/Lot Number
    
    const gs1Data = `(01)${gtin}(21)${serialNumber}(17)${expiryDate}(10)${batchNumber}`;
    
    // Generate QR code as Data URL (base64-encoded PNG)
    const qrCodeImage = await QRCode.toDataURL(gs1Data, {
      type: 'image/png',
      errorCorrectionLevel: 'H',  // High error correction (30% damage tolerance)
      width: 200,                  // 200x200 pixels
      margin: 1,                   // Minimal white border
      color: {
        dark: '#000000',
        light: '#FFFFFF'
      }
    });
    
    return {
      gs1Data,           // Raw GS1 string
      qrCodeImage,       // Base64 PNG: "data:image/png;base64,iVBORw0KG..."
      serialNumber       // For reference
    };
  }
  
  /**
   * Generate box-level QR code
   * Contains box ID and list of serial numbers inside
   */
  async generateBoxQR(boxId, serialNumbers) {
    // For box QR, we encode the box ID
    // The system will look up box contents in database
    const boxData = {
      type: 'BOX',
      boxId: boxId,
      count: serialNumbers.length
      // Don't encode full list of serials in QR (too large)
      // Database lookup is more reliable
    };
    
    const qrCodeImage = await QRCode.toDataURL(JSON.stringify(boxData), {
      errorCorrectionLevel: 'H',
      width: 250
    });
    
    return {
      boxId,
      qrCodeImage,
      containsSerials: serialNumbers
    };
  }
  
  /**
   * Generate printable PDF with all QR codes
   */
  async generatePrintablePDF(qrCodes, productInfo) {
    const PDFDocument = require('pdfkit');
    const doc = new PDFDocument();
    
    // Title
    doc.fontSize(16).text(`QR Codes for ${productInfo.productName}`, { align: 'center' });
    doc.fontSize(10).text(`Batch: ${productInfo.batchNumber}`, { align: 'center' });
    doc.moveDown();
    
    // Grid layout: 4 columns × 6 rows = 24 QR codes per page
    const qrSize = 120;
    const margin = 40;
    const cols = 4;
    const rows = 6;
    
    let col = 0;
    let row = 0;
    
    qrCodes.forEach((qr, index) => {
      // Calculate position
      const x = margin + (col * (qrSize + 20));
      const y = margin + 100 + (row * (qrSize + 40));
      
      // Add QR code image
      doc.image(qr.qrCodeImage, x, y, { width: qrSize, height: qrSize });
      
      // Add serial number below QR
      doc.fontSize(8).text(qr.serialNumber, x, y + qrSize + 5, {
        width: qrSize,
        align: 'center'
      });
      
      // Move to next position
      col++;
      if (col >= cols) {
        col = 0;
        row++;
      }
      
      // New page after 24 codes
      if (row >= rows) {
        doc.addPage();
        col = 0;
        row = 0;
      }
    });
    
    doc.end();
    return doc;
  }
  
  /**
   * Parse GS1 barcode data
   * Used when scanning QR codes
   */
  parseGS1(scannedData) {
    // Example input: "(01)05412345678900(21)2024-PFZ-ASP-0001234(17)260630(10)BATCH-2024-001"
    
    const parsed = {};
    
    // Extract GTIN (01)
    const gtinMatch = scannedData.match(/\(01\)(\d{14})/);
    if (gtinMatch) parsed.gtin = gtinMatch[1];
    
    // Extract Serial (21)
    const serialMatch = scannedData.match(/\(21\)([^\(]+)/);
    if (serialMatch) parsed.serialNumber = serialMatch[1];
    
    // Extract Expiry (17) - Format: YYMMDD
    const expiryMatch = scannedData.match(/\(17\)(\d{6})/);
    if (expiryMatch) {
      const exp = expiryMatch[1];
      // Convert YYMMDD to YYYY-MM-DD
      parsed.expiryDate = `20${exp.substring(0,2)}-${exp.substring(2,4)}-${exp.substring(4,6)}`;
    }
    
    // Extract Batch (10)
    const batchMatch = scannedData.match(/\(10\)([^\(]+)/);
    if (batchMatch) parsed.batchNumber = batchMatch[1];
    
    return parsed;
  }
}

module.exports = new QRCodeService();
6.3 Verification Logic (CRITICAL)
This is the heart of the system - where counterfeits are detected.

javascript
// services/verificationService.js

class VerificationService {
  
  /**
   * Verify medicine authenticity
   * @param {string} serialNumber - Scanned serial number
   * @param {string} actorId - Who is scanning (pharmacy ID)
   * @param {string} actionType - 'verify' or 'dispense'
   * @returns {Object} Verification result
   */
  async verifyMedicine(serialNumber, actorId, actionType = 'verify') {
    
    // ========================================
    // CHECK 1: Does serial number exist?
    // ========================================
    const medicine = await db.query(`
      SELECT 
        sn.*,
        p.product_name,
        p.gtin,
        m.company_name as manufacturer_name
      FROM serial_numbers sn
      JOIN products p ON sn.product_id = p.product_id
      JOIN manufacturers m ON p.manufacturer_id = m.manufacturer_id
      WHERE sn.serial_number = $1
    `, [serialNumber]);
    
    if (!medicine.rows.length) {
      // Serial doesn't exist in database
      await this.logVerification(serialNumber, actorId, 'invalid', 'Serial number not found');
      await this.createAlert({
        type: 'invalid_code',
        serialNumber,
        actorId,
        severity: 'critical',
        description: `Invalid serial number scanned: ${serialNumber}`
      });
      
      return {
        valid: false,
        reason: 'invalid_serial',
        message: '❌ COUNTERFEIT DETECTED: Serial number not found in database',
        alertLevel: 'critical'
      };
    }
    
    const med = medicine.rows[0];
    
    // ========================================
    // CHECK 2: Already dispensed?
    // ========================================
    if (med.status === 'dispensed') {
      // Medicine already sold to someone else
      const previousTransaction = await db.query(`
        SELECT 
          t.transaction_date,
          t.to_actor_id,
          a.company_name,
          a.city
        FROM transactions t
        LEFT JOIN supply_chain_actors a ON t.to_actor_id = a.actor_id
        WHERE t.serial_number = $1 
          AND t.transaction_type = 'dispense'
        ORDER BY t.transaction_date DESC
        LIMIT 1
      `, [serialNumber]);
      
      const prevTx = previousTransaction.rows[0];
      
      await this.createAlert({
        type: 'duplicate_scan',
        serialNumber,
        actorId,
        severity: 'critical',
        description: `Duplicate serial detected. Already dispensed at ${prevTx.company_name} on ${prevTx.transaction_date}`
      });
      
      return {
        valid: false,
        reason: 'already_dispensed',
        message: `⚠️ DUPLICATE DETECTED: This medicine was already dispensed on ${new Date(prevTx.transaction_date).toLocaleDateString()} at ${prevTx.company_name}, ${prevTx.city}`,
        alertLevel: 'critical',
        previousTransaction: prevTx
      };
    }
    
    // ========================================
    // CHECK 3: Expired?
    // ========================================
    const today = new Date();
    const expiryDate = new Date(med.expiry_date);
    
    if (expiryDate < today) {
      await this.logVerification(serialNumber, actorId, 'expired', 'Medicine past expiration date');
      
      return {
        valid: false,
        reason: 'expired',
        message: `⚠️ EXPIRED: This medicine expired on ${med.expiry_date}`,
        alertLevel: 'medium',
        medicine: {
          product_name: med.product_name,
          batch_number: med.batch_number,
          expiry_date: med.expiry_date
        }
      };
    }
    
    // ========================================
    // CHECK 4: Recalled?
    // ========================================
    const recalled = await db.query(`
      SELECT recall_id, recall_reason, severity
      FROM recalls
      WHERE product_id = $1
        AND $2 = ANY(batch_numbers)
        AND status = 'active'
    `, [med.product_id, med.batch_number]);
    
    if (recalled.rows.length > 0) {
      const recall = recalled.rows[0];
      
      await this.createAlert({
        type: 'recalled_product',
        serialNumber,
        actorId,
        severity: 'critical',
        description: `Recalled medicine scanned: ${recall.recall_reason}`
      });
      
      return {
        valid: false,
        reason: 'recalled',
        message: `🚫 RECALLED PRODUCT: ${recall.recall_reason}. DO NOT DISPENSE.`,
        alertLevel: 'critical',
        recallInfo: recall
      };
    }
    
    // ========================================
    // CHECK 5: Valid supply chain sequence?
    // ========================================
    const chainValid = await this.verifySupplyChain(serialNumber, actorId);
    
    if (!chainValid.valid) {
      await this.createAlert({
        type: 'unauthorized_location',
        serialNumber,
        actorId,
        severity: 'high',
        description: chainValid.message
      });
      
      return chainValid;
    }
    
    // ========================================
    // ALL CHECKS PASSED ✅
    // ========================================
    
    if (actionType === 'dispense') {
      // Update status to dispensed
      await db.query(`
        UPDATE serial_numbers
        SET status = 'dispensed',
            dispensed_at = NOW(),
            dispensed_by = $2,
            updated_at = NOW()
        WHERE serial_number = $1
      `, [serialNumber, actorId]);
      
      // Log dispensing transaction
      await db.query(`
        INSERT INTO transactions 
        (serial_number, transaction_type, from_actor_id, to_actor_id, scanned_by)
        VALUES ($1, 'dispense', $2, 'PATIENT', $3)
      `, [serialNumber, actorId, actorId]);
    }
    
    // Log successful verification
    await this.logVerification(serialNumber, actorId, 'valid', null);
    
    return {
      valid: true,
      reason: 'authentic',
      message: '✅ GENUINE MEDICINE - Safe to dispense',
      alertLevel: 'none',
      medicine: {
        serial_number: serialNumber,
        product_name: med.product_name,
        manufacturer: med.manufacturer_name,
        batch_number: med.batch_number,
        manufacturing_date: med.manufacturing_date,
        expiry_date: med.expiry_date,
        status: med.status
      }
    };
  }
  
  /**
   * Verify supply chain sequence
   * Ensures medicine followed correct path: manufacturer → wholesaler → pharmacy
   */
  async verifySupplyChain(serialNumber, currentActorId) {
    // Get all transactions for this medicine
    const transactions = await db.query(`
      SELECT 
        t.transaction_type,
        t.from_actor_id,
        t.to_actor_id,
        a1.actor_type as from_type,
        a2.actor_type as to_type,
        t.transaction_date
      FROM transactions t
      LEFT JOIN supply_chain_actors a1 ON t.from_actor_id = a1.actor_id
      LEFT JOIN supply_chain_actors a2 ON t.to_actor_id = a2.actor_id
      WHERE t.serial_number = $1
      ORDER BY t.transaction_date ASC
    `, [serialNumber]);
    
    const txs = transactions.rows;
    
    if (txs.length === 0) {
      // No previous transactions (just manufactured)
      return { valid: true };
    }
    
    // Expected sequence: manufacturer → wholesaler → pharmacy → patient
    const lastTx = txs[txs.length - 1];
    
    // Get current actor type
    const currentActor = await db.query(
      'SELECT actor_type FROM supply_chain_actors WHERE actor_id = $1',
      [currentActorId]
    );
    
    if (!currentActor.rows.length) {
      return {
        valid: false,
        reason: 'unknown_actor',
        message: '⚠️ Unknown scanning location'
      };
    }
    
    const currentType = currentActor.rows[0].actor_type;
    
    // Validate sequence
    // If last location was wholesaler, current should be pharmacy/hospital
    // If last location was pharmacy, current should be same pharmacy (for dispensing)
    
    if (lastTx.to_type === 'wholesaler' && currentType === 'pharmacy') {
      return { valid: true }; // Valid transition
    }
    
    if (lastTx.to_type === 'pharmacy' && lastTx.to_actor_id === currentActorId) {
      return { valid: true }; // Same pharmacy dispensing
    }
    
    // Suspicious: Medicine jumped from one pharmacy to another
    if (lastTx.to_type === 'pharmacy' && lastTx.to_actor_id !== currentActorId) {
      return {
        valid: false,
        reason: 'suspicious_transfer',
        message: `⚠️ SUSPICIOUS: Medicine was at a different pharmacy. Possible diversion or theft.`,
        alertLevel: 'high'
      };
    }
    
    return { valid: true }; // Default to valid if no issues
  }
  
  /**
   * Log verification attempt
   */
  async logVerification(serialNumber, requestedBy, result, reason) {
    await db.query(`
      INSERT INTO verifications 
      (serial_number, requested_by, verification_result, failure_reason)
      VALUES ($1, $2, $3, $4)
    `, [serialNumber, requestedBy, result, reason]);
  }
  
  /**
   * Create alert for regulators
   */
  async createAlert(alertData) {
    const alert = await db.query(`
      INSERT INTO alerts 
      (alert_type, serial_number, actor_id, severity, description)
      VALUES ($1, $2, $3, $4, $5)
      RETURNING alert_id
    `, [
      alertData.type,
      alertData.serialNumber || null,
      alertData.actorId,
      alertData.severity,
      alertData.description
    ]);
    
    // TODO: Send real-time notification via WebSocket
    // this.notifyRegulators(alert.rows[0].alert_id);
    
    return alert.rows[0];
  }
}

module.exports = new VerificationService();
